{% extends 'base.html.twig' %}

{% block title %}Panier{% endblock %}

{% block body %}
    <h2 class="page-title">Votre panier</h2>

    {% set totalItems = 0 %}
    {% for item in panier %}
        {% set totalItems = totalItems + item.quantity %}
    {% endfor %}

    {% if panier is empty %}
        <p style="text-align:center;">Votre panier est vide.</p>
    {% else %}
        <ul class="panier-list">
            {% for id, item in panier %}
                <li class="panier-item">

                    <span>{{ item.name }}</span>

                    <div class="panier-actions">
                        <form method="post" action="{{ path('panier_update', {id: id}) }}">
                            <input type="hidden" name="action" value="minus">
                            <button type="submit">−</button>
                        </form>

                        <strong>{{ item.quantity }}</strong>

                        <form method="post" action="{{ path('panier_update', {id: id}) }}">
                            <input type="hidden" name="action" value="plus">
                        <button type="submit" {% if totalItems >= 2 %}disabled{% endif %}>+</button>                        </form>

                        <form method="post" action="{{ path('panier_remove', {id: id}) }}">
                            <button type="submit">❌</button>
                        </form>
                    </div>

                </li>
            {% endfor %}
        </ul>
    {% endif %}


    {% if panier is not empty %}
        <form method="post" action="{{ path('validation') }}" class="validate-form">
            <button type="submit" class="validate-btn">
                Valider la réservation
            </button>
        </form>
    {% endif %}


{% endblock %}
